{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "description": "Spark suite for Pi: project/task orchestration with controlled agents, artifacts, review, ask, and cue execution primitives.",
  "keywords": [
    "agentic-workflow",
    "pi",
    "pi-package",
    "spark"
  ],
  "license": "MIT",
  "author": "zrr1999",
  "bin": {
    "spark": "./apps/spark-cli/bin/spark"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "check": "pnpm --filter @zendev-lab/spark-cockpit exec svelte-kit sync && node scripts/check-pi-boundaries.mjs && vp check && node --experimental-strip-types --test \"test/*.test.ts\" && pnpm -r --filter './packages/*' --filter './apps/*' run check && pnpm --filter @zendev-lab/spark-cockpit run test && pnpm --filter @zendev-lab/spark-daemon run test",
    "build": "pnpm --filter @zendev-lab/spark-daemon run build && pnpm --filter @zendev-lab/spark-cockpit run build",
    "preview": "pnpm --filter @zendev-lab/spark-cockpit run dev",
    "publish": "pnpm run check && pnpm run build && pnpm -r --filter @zendev-lab/spark-protocol --filter @zendev-lab/spark-system --filter @zendev-lab/spark-db --filter @zendev-lab/spark-daemon publish --access public"
  },
  "dependencies": {
    "@zendev-lab/pi-artifacts": "workspace:^",
    "@zendev-lab/pi-ask": "workspace:^",
    "@zendev-lab/pi-btw": "workspace:^",
    "@zendev-lab/pi-context": "workspace:^",
    "@zendev-lab/pi-cue": "workspace:^",
    "@zendev-lab/pi-extension-api": "workspace:^",
    "@zendev-lab/pi-goal": "workspace:^",
    "@zendev-lab/pi-graft": "workspace:^",
    "@zendev-lab/pi-learnings": "workspace:^",
    "@zendev-lab/pi-recall": "workspace:^",
    "@zendev-lab/pi-roles": "workspace:^",
    "@zendev-lab/pi-tasks": "workspace:^",
    "@zendev-lab/pi-workflows": "workspace:^",
    "@zendev-lab/spark-protocol": "workspace:^",
    "@zendev-lab/spark-runtime": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "typebox": "^1.2.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@zendev-lab/spark-system": "workspace:*",
    "oxlint": "1.70.0",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.7.0",
  "pi": {
    "extensions": [
      "./packages/pi-ask/src/extension-entry.ts",
      "./packages/pi-artifacts/src/extension-entry.ts",
      "./packages/pi-btw/extensions/btw.ts",
      "./packages/pi-cue/src/extension/index.ts",
      "./packages/pi-models/src/extension-entry.ts",
      "./packages/pi-roles/src/extension-entry.ts",
      "./packages/pi-recall/src/extension-entry.ts",
      "./packages/pi-workflows/src/extension-entry.ts",
      "./packages/pi-graft/src/extension-entry.ts",
      "./apps/spark-tui/src/baidu-oneapi-provider.ts",
      "./packages/spark-extension/src/extension/index.ts"
    ],
    "skills": [
      "./packages/pi-btw/skills"
    ]
  }
}
