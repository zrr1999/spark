{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "description": "Spark monorepo: daemon-first agent orchestration across TUI, Cockpit, and channels, with Pi product compatibility retained.",
  "keywords": [
    "Agentic Workflow",
    "Coding Agent",
    "Spark"
  ],
  "homepage": "https://github.com/zrr1999/spark#readme",
  "bugs": {
    "url": "https://github.com/zrr1999/spark/issues"
  },
  "license": "MIT",
  "author": "zrr1999",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zrr1999/spark.git"
  },
  "bin": {
    "spark": "./apps/spark-cli/bin/spark"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "check": "pnpm run check:static && pnpm run test:unit && pnpm run test:process:source",
    "check:static": "pnpm --filter @zendev-lab/spark-cockpit exec svelte-kit sync && node scripts/check-architecture-ratchets.mjs && node scripts/check-npm-product.mjs && depcruise --config .dependency-cruiser.cjs apps packages test && pnpm run check:test-quality && node scripts/check-doc-terminology.mjs && vp fmt . --check && vp lint --quiet && pnpm run typecheck",
    "fix": "pnpm --filter @zendev-lab/spark-cockpit exec svelte-kit sync && vp fmt . --write && vp lint --fix --quiet && pnpm run typecheck",
    "typecheck": "pnpm --filter @zendev-lab/spark-cockpit run check && vp check --no-fmt --no-lint && pnpm --filter @zendev-lab/spark-daemon run check",
    "check:test-quality": "node scripts/check-test-quality.mjs",
    "check:test-quality:update": "node scripts/check-test-quality.mjs --update",
    "test": "vp test run --config vitest.root.config.ts",
    "test:unit": "vp test run --config vitest.root.config.ts && pnpm -r --filter './packages/*' --if-present run check && pnpm --filter @zendev-lab/spark-cockpit run test && pnpm --filter @zendev-lab/spark-daemon run test",
    "test:process:source": "vp test run --config vitest.process.config.ts",
    "test:browser:cockpit": "pnpm --filter @zendev-lab/spark-cockpit run test:browser",
    "test:mutation": "node scripts/run-leaf-mutation.mjs",
    "build": "pnpm --filter @zendev-lab/spark-daemon run build && pnpm --filter @zendev-lab/spark-cockpit run build",
    "release:pack": "node scripts/pack-release.mjs",
    "preview": "pnpm --filter @zendev-lab/spark-cockpit run dev",
    "smoke": "node scripts/smoke-npm-product.mjs",
    "audit": "pnpm audit --registry=https://registry.npmjs.org/ --audit-level high",
    "report:hygiene": "node scripts/report-hygiene.mjs",
    "prepare": "prek install --hook-type commit-msg --hook-type pre-commit"
  },
  "dependencies": {
    "@zendev-lab/spark-ai": "workspace:^",
    "@zendev-lab/spark-artifacts": "workspace:^",
    "@zendev-lab/spark-ask": "workspace:^",
    "@zendev-lab/spark-channels": "workspace:^",
    "@zendev-lab/spark-cockpit-coordination": "workspace:^",
    "@zendev-lab/spark-core": "workspace:^",
    "@zendev-lab/spark-cue": "workspace:^",
    "@zendev-lab/spark-files": "workspace:^",
    "@zendev-lab/spark-fusion": "workspace:^",
    "@zendev-lab/spark-graft": "workspace:^",
    "@zendev-lab/spark-host": "workspace:^",
    "@zendev-lab/spark-loop": "workspace:^",
    "@zendev-lab/spark-memory": "workspace:^",
    "@zendev-lab/spark-protocol": "workspace:^",
    "@zendev-lab/spark-repro": "workspace:^",
    "@zendev-lab/spark-roles": "workspace:^",
    "@zendev-lab/spark-runtime": "workspace:^",
    "@zendev-lab/spark-session": "workspace:^",
    "@zendev-lab/spark-tasks": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "@zendev-lab/spark-tui-app": "workspace:^",
    "@zendev-lab/spark-turn": "workspace:^",
    "@zendev-lab/spark-update": "workspace:^",
    "@zendev-lab/spark-web": "workspace:^",
    "@zendev-lab/spark-workflows": "workspace:^",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@j178/prek": "0.4.6",
    "@types/node": "^26.1.1",
    "@zendev-lab/spark-daemon-client": "workspace:*",
    "@zendev-lab/spark-system": "workspace:*",
    "dependency-cruiser": "^18.1.0",
    "es-toolkit": "catalog:",
    "esbuild": "^0.28.0",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "p-retry": "catalog:",
    "tsx": "^4.20.5",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "optionalDependencies": {
    "@cursor/sdk-darwin-arm64": "1.0.23",
    "@cursor/sdk-darwin-x64": "1.0.23",
    "@cursor/sdk-linux-arm64": "1.0.23",
    "@cursor/sdk-linux-x64": "1.0.23",
    "@cursor/sdk-win32-x64": "1.0.23"
  },
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.8.0",
  "pi": {
    "extensions": [
      "./packages/spark-ask/src/extension-entry.ts",
      "./packages/spark-artifacts/src/extension-entry.ts",
      "./packages/spark-cue/src/extension/index.ts",
      "./packages/spark-files/src/extension-entry.ts",
      "./packages/spark-ai/src/models-extension.ts",
      "./packages/spark-roles/src/extension-entry.ts",
      "./packages/spark-session/src/extension-entry.ts",
      "./packages/spark-memory/src/extension-entry.ts",
      "./packages/spark-web/src/extension-entry.ts",
      "./packages/spark-workflows/src/extension-entry.ts",
      "./packages/spark-ai/src/baidu-oneapi-provider.ts",
      "./packages/spark-extension/src/extension/index.ts"
    ]
  },
  "sparkRelease": {
    "minimumUpdaterVersion": "0.1.0",
    "rollbackCompatibility": ">=0.1.0 <0.2.0",
    "migrationMode": "expand-only"
  }
}
