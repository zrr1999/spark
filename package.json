{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "description": "Spark monorepo: daemon-first agent orchestration across TUI, Cockpit, and channels, with Pi product compatibility retained.",
  "keywords": [
    "Agentic Workflow",
    "Coding Agent",
    "Spark"
  ],
  "license": "MIT",
  "author": "zrr1999",
  "bin": {
    "spark": "./apps/spark-cli/bin/spark"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "check": "pnpm --filter @zendev-lab/spark-cockpit exec svelte-kit sync && pnpm run check:architecture && pnpm run check:boundaries && node scripts/check-doc-terminology.mjs && pnpm run check:static && vp test run --config vitest.root.config.ts && pnpm -r --filter './packages/*' --filter './apps/*' run check && pnpm --filter @zendev-lab/spark-cockpit run test && pnpm --filter @zendev-lab/spark-daemon run test",
    "check:architecture": "node scripts/check-architecture-ratchets.mjs",
    "check:static": "vp fmt . --check && vp lint --quiet && vp check --no-fmt --no-lint",
    "check:static:fix": "vp fmt . --write && vp lint --fix --quiet && vp check --no-fmt --no-lint",
    "check:boundaries": "depcruise --config .dependency-cruiser.cjs apps packages test",
    "check:knip": "knip --no-progress --no-config-hints || true",
    "check:dup": "mkdir -p reports/jscpd && jscpd --config .jscpd.json apps packages || true",
    "check:complexity": "vp lint -A all -W complexity -W max-lines --ignore-pattern '**/*.test.ts' --ignore-pattern 'packages/spark-cockpit-i18n/**' --ignore-pattern 'packages/spark-i18n/**' apps packages 2>&1 | head -n 200 || true",
    "check:security": "pnpm audit --registry=https://registry.npmjs.org/ --audit-level high",
    "check:tsc": "vp check --no-fmt --no-lint",
    "check:daemon-readiness": "node --experimental-strip-types scripts/spark-daemon-readiness.mts",
    "check:cue-harness": "node --experimental-strip-types scripts/spark-cue-harness.mts --no-exercise",
    "check:cue-contract": "node --experimental-strip-types scripts/spark-cue-contract-harness.mts",
    "check:zellij-harness": "node --experimental-strip-types scripts/spark-zellij-harness.mts",
    "format": "vp fmt . --write",
    "test": "vp test run --config vitest.root.config.ts",
    "test:file": "vp test run --config vitest.root.config.ts",
    "test:mutation": "node scripts/run-leaf-mutation.mjs",
    "build": "pnpm --filter @zendev-lab/spark-daemon run build && pnpm --filter @zendev-lab/spark-cockpit run build",
    "preview": "pnpm --filter @zendev-lab/spark-cockpit run dev",
    "publish": "pnpm run check && pnpm run build && pnpm -r --filter @zendev-lab/spark-repro --filter @zendev-lab/spark-retry --filter './apps/*' --filter @zendev-lab/pi-extension publish --access public",
    "prepare": "prek install --hook-type commit-msg --hook-type pre-commit"
  },
  "dependencies": {
    "@zendev-lab/pi-btw": "workspace:^",
    "@zendev-lab/spark-ai": "workspace:^",
    "@zendev-lab/spark-artifacts": "workspace:^",
    "@zendev-lab/spark-ask": "workspace:^",
    "@zendev-lab/spark-channels": "workspace:^",
    "@zendev-lab/spark-cockpit-coordination": "workspace:^",
    "@zendev-lab/spark-context": "workspace:^",
    "@zendev-lab/spark-core": "workspace:^",
    "@zendev-lab/spark-cue": "workspace:^",
    "@zendev-lab/spark-files": "workspace:^",
    "@zendev-lab/spark-graft": "workspace:^",
    "@zendev-lab/spark-host": "workspace:^",
    "@zendev-lab/spark-loop": "workspace:^",
    "@zendev-lab/spark-memory": "workspace:^",
    "@zendev-lab/spark-protocol": "workspace:^",
    "@zendev-lab/spark-repro": "workspace:^",
    "@zendev-lab/spark-roles": "workspace:^",
    "@zendev-lab/spark-runtime": "workspace:^",
    "@zendev-lab/spark-session": "workspace:^",
    "@zendev-lab/spark-tasks": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "@zendev-lab/spark-tui-app": "workspace:^",
    "@zendev-lab/spark-turn": "workspace:^",
    "@zendev-lab/spark-web": "workspace:^",
    "@zendev-lab/spark-workflows": "workspace:^",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@j178/prek": "0.4.6",
    "@types/node": "^26.1.1",
    "@zendev-lab/spark-system": "workspace:*",
    "dependency-cruiser": "^18.1.0",
    "es-toolkit": "catalog:",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "p-retry": "catalog:",
    "tsx": "^4.20.5",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "optionalDependencies": {
    "@cursor/sdk-darwin-arm64": "1.0.23",
    "@cursor/sdk-darwin-x64": "1.0.23",
    "@cursor/sdk-linux-arm64": "1.0.23",
    "@cursor/sdk-linux-x64": "1.0.23",
    "@cursor/sdk-win32-x64": "1.0.23"
  },
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.8.0",
  "pi": {
    "extensions": [
      "./packages/spark-ask/src/extension-entry.ts",
      "./packages/spark-artifacts/src/extension-entry.ts",
      "./packages/pi-btw/extensions/btw.ts",
      "./packages/spark-cue/src/extension/index.ts",
      "./packages/spark-files/src/extension-entry.ts",
      "./packages/spark-ai/src/models-extension.ts",
      "./packages/spark-roles/src/extension-entry.ts",
      "./packages/spark-session/src/extension-entry.ts",
      "./packages/spark-memory/src/extension-entry.ts",
      "./packages/spark-web/src/extension-entry.ts",
      "./packages/spark-workflows/src/extension-entry.ts",
      "./packages/spark-ai/src/baidu-oneapi-provider.ts",
      "./packages/pi-extension/src/extension/index.ts"
    ],
    "skills": [
      "./packages/pi-btw/skills"
    ]
  }
}
