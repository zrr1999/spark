{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "description": "Spark suite for Pi: project/task orchestration with controlled agents, artifacts, review, ask, and cue execution primitives.",
  "keywords": [
    "agentic-workflow",
    "pi",
    "pi-package",
    "spark"
  ],
  "license": "MIT",
  "author": "zrr1999",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "check": "pnpm run svelte:sync && vp check",
    "check:fix": "pnpm run svelte:sync && vp check --fix",
    "check:boundaries": "node scripts/check-pi-boundaries.mjs",
    "check:tsc": "tsc -p tsconfig.json --noEmit",
    "check:packages": "pnpm -r --filter './packages/*' --filter './apps/*' run check",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "lint": "vp lint . --fix",
    "lint:check": "vp lint .",
    "test": "node --experimental-strip-types --test \"test/*.test.ts\"",
    "test:file": "node --experimental-strip-types --test",
    "verify": "pnpm run check && pnpm test",
    "prepare": "pnpx @j178/prek install --hook-type commit-msg --hook-type pre-commit",
    "svelte:sync": "pnpm --filter @zendev-lab/navia-web exec svelte-kit sync",
    "navia:check": "pnpm --filter '@zendev-lab/navia-*' run check",
    "navia:test": "pnpm --filter '@zendev-lab/navia-*' run test",
    "navia:e2e": "pnpm --filter @zendev-lab/navia-runner exec vp test run src/daemon.test.ts -t 'streams ack, running, log chunks, and succeeded updates from the Spark bridge'",
    "navia:build": "pnpm --filter @zendev-lab/navia-runner run build && pnpm --filter @zendev-lab/navia-web run build",
    "verify:navia": "pnpm run navia:check && pnpm run navia:test && pnpm run navia:build",
    "verify:merged": "pnpm run check:boundaries && pnpm run check:tsc && pnpm test && pnpm run verify:navia",
    "navia:web": "pnpm --filter @zendev-lab/navia-web run dev",
    "navia:runner": "pnpm --filter @zendev-lab/navia-runner run cli",
    "navia:install": "pnpm --filter @zendev-lab/navia-runner run build && node scripts/link-navia-runner.mjs"
  },
  "dependencies": {
    "@zendev-lab/pi-artifacts": "workspace:^",
    "@zendev-lab/pi-ask": "workspace:^",
    "@zendev-lab/pi-btw": "workspace:^",
    "@zendev-lab/pi-context": "workspace:^",
    "@zendev-lab/pi-cue": "workspace:^",
    "@zendev-lab/pi-extension-api": "workspace:^",
    "@zendev-lab/pi-goal": "workspace:^",
    "@zendev-lab/pi-graft": "workspace:^",
    "@zendev-lab/pi-learnings": "workspace:^",
    "@zendev-lab/pi-recall": "workspace:^",
    "@zendev-lab/pi-roles": "workspace:^",
    "@zendev-lab/pi-tasks": "workspace:^",
    "@zendev-lab/pi-workflows": "workspace:^",
    "@zendev-lab/spark-runtime": "workspace:^",
    "typebox": "^1.2.13"
  },
  "devDependencies": {
    "@earendil-works/pi-tui": "0.79.4",
    "@types/node": "^25.9.3",
    "@zendev-lab/navia-protocol": "workspace:*",
    "@zendev-lab/navia-system": "workspace:*",
    "oxlint": "1.70.0",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.7.0",
  "pi": {
    "extensions": [
      "./packages/pi-ask/src/extension-entry.ts",
      "./packages/pi-artifacts/src/extension-entry.ts",
      "./packages/pi-btw/extensions/btw.ts",
      "./packages/pi-cue/src/extension/index.ts",
      "./packages/pi-models/src/extension-entry.ts",
      "./packages/pi-roles/src/extension-entry.ts",
      "./packages/pi-recall/src/extension-entry.ts",
      "./packages/pi-workflows/src/extension-entry.ts",
      "./packages/pi-graft/src/extension-entry.ts",
      "./apps/spark/src/baidu-oneapi-provider.ts",
      "./packages/spark/src/extension/index.ts"
    ],
    "skills": [
      "./packages/pi-btw/skills"
    ]
  }
}
