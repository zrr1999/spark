{
  "name": "spark",
  "version": "0.1.0",
  "private": true,
  "description": "Spark suite for Pi: project/task orchestration with controlled agents, artifacts, review, ask, and cue execution primitives.",
  "keywords": [
    "Agentic Workflow",
    "Coding Agent",
    "Spark"
  ],
  "license": "MIT",
  "author": "zrr1999",
  "bin": {
    "spark": "./apps/spark-cli/bin/spark"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "check": "pnpm --filter @zendev-lab/spark-cockpit exec svelte-kit sync && node scripts/check-pi-boundaries.mjs && node scripts/check-doc-terminology.mjs && vp check && node --experimental-strip-types --test \"test/*.test.ts\" && pnpm -r --filter './packages/*' --filter './apps/*' run check && pnpm --filter @zendev-lab/spark-cockpit run test && pnpm --filter @zendev-lab/spark-daemon run test",
    "check:tsc": "tsc -p tsconfig.json --noEmit",
    "format": "vp fmt . --write",
    "test": "node --experimental-strip-types --test \"test/*.test.ts\"",
    "test:file": "node --experimental-strip-types --test",
    "build": "pnpm --filter @zendev-lab/spark-daemon run build && pnpm --filter @zendev-lab/spark-cockpit run build",
    "preview": "pnpm --filter @zendev-lab/spark-cockpit run dev",
    "publish": "pnpm run check && pnpm run build && pnpm -r --filter './apps/*' --filter @zendev-lab/pi-extension publish --access public",
    "prepare": "pnpx @j178/prek install --hook-type commit-msg --hook-type pre-commit"
  },
  "dependencies": {
    "@zendev-lab/pi-btw": "workspace:^",
    "@zendev-lab/spark-ai": "workspace:^",
    "@zendev-lab/spark-artifacts": "workspace:^",
    "@zendev-lab/spark-ask": "workspace:^",
    "@zendev-lab/spark-context": "workspace:^",
    "@zendev-lab/spark-cue": "workspace:^",
    "@zendev-lab/spark-extension-api": "workspace:^",
    "@zendev-lab/spark-files": "workspace:^",
    "@zendev-lab/spark-graft": "workspace:^",
    "@zendev-lab/spark-host": "workspace:^",
    "@zendev-lab/spark-learnings": "workspace:^",
    "@zendev-lab/spark-loop": "workspace:^",
    "@zendev-lab/spark-protocol": "workspace:^",
    "@zendev-lab/spark-recall": "workspace:^",
    "@zendev-lab/spark-roles": "workspace:^",
    "@zendev-lab/spark-runtime": "workspace:^",
    "@zendev-lab/spark-server": "workspace:^",
    "@zendev-lab/spark-tasks": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "@zendev-lab/spark-tui-app": "workspace:^",
    "@zendev-lab/spark-turn": "workspace:^",
    "@zendev-lab/spark-workflows": "workspace:^",
    "typebox": "^1.2.13"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@zendev-lab/spark-system": "workspace:*",
    "oxlint": "1.70.0",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.8.0",
  "pi": {
    "extensions": [
      "./packages/spark-ask/src/extension-entry.ts",
      "./packages/spark-artifacts/src/extension-entry.ts",
      "./packages/pi-btw/extensions/btw.ts",
      "./packages/spark-cue/src/extension/index.ts",
      "./packages/spark-files/src/extension-entry.ts",
      "./packages/spark-ai/src/models-extension.ts",
      "./packages/spark-roles/src/extension-entry.ts",
      "./packages/spark-recall/src/extension-entry.ts",
      "./packages/spark-workflows/src/extension-entry.ts",
      "./packages/spark-graft/src/extension-entry.ts",
      "./packages/spark-ai/src/baidu-oneapi-provider.ts",
      "./packages/pi-extension/src/extension/index.ts"
    ],
    "skills": [
      "./packages/pi-btw/skills"
    ]
  }
}
