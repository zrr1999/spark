{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@zendev-lab/pi-artifacts": ["./packages/pi-artifacts/src/index.ts"],
      "@zendev-lab/pi-artifacts/extension": ["./packages/pi-artifacts/src/extension.ts"],
      "@zendev-lab/pi-ask": ["./packages/pi-ask/src/index.ts"],
      "@zendev-lab/pi-ask/extension": ["./packages/pi-ask/src/extension.ts"],
      "@zendev-lab/pi-context": ["./packages/pi-context/src/index.ts"],
      "@zendev-lab/pi-context/extension": ["./packages/pi-context/src/extension.ts"],
      "@zendev-lab/pi-cue": ["./packages/pi-cue/src/index.ts"],
      "@zendev-lab/pi-cue/extension": ["./packages/pi-cue/src/extension/index.ts"],
      "@zendev-lab/pi-extension-api": ["./packages/pi-extension-api/src/index.ts"],
      "@zendev-lab/pi-goal": ["./packages/pi-goal/src/index.ts"],
      "@zendev-lab/pi-graft": ["./packages/pi-graft/src/index.ts"],
      "@zendev-lab/pi-graft/extension": ["./packages/pi-graft/src/extension.ts"],
      "@zendev-lab/pi-learnings": ["./packages/pi-learnings/src/index.ts"],
      "@zendev-lab/pi-learnings/extension": ["./packages/pi-learnings/src/extension.ts"],
      "@zendev-lab/pi-models": ["./packages/pi-models/src/index.ts"],
      "@zendev-lab/pi-models/extension": ["./packages/pi-models/src/extension.ts"],
      "@zendev-lab/pi-modes": ["./packages/pi-modes/src/index.ts"],
      "@zendev-lab/pi-recall": ["./packages/pi-recall/src/index.ts"],
      "@zendev-lab/pi-recall/extension": ["./packages/pi-recall/src/extension.ts"],
      "@zendev-lab/pi-roles": ["./packages/pi-roles/src/index.ts"],
      "@zendev-lab/pi-roles/extension": ["./packages/pi-roles/src/extension.ts"],
      "@zendev-lab/pi-tasks": ["./packages/pi-tasks/src/index.ts"],
      "@zendev-lab/pi-tasks/extension": ["./packages/pi-tasks/src/extension.ts"],
      "@zendev-lab/pi-workflows": ["./packages/pi-workflows/src/index.ts"],
      "@zendev-lab/pi-workflows/extension": ["./packages/pi-workflows/src/extension.ts"],
      "@zendev-lab/spark-cli/baidu-oneapi-provider": ["./apps/spark/src/baidu-oneapi-provider.ts"],
      "@zendev-lab/spark-runtime": ["./packages/spark-runtime/src/index.ts"],
      "@zendev-lab/spark/extension": ["./packages/spark/src/extension/index.ts"]
    },
    "lib": ["ES2024", "DOM", "DOM.Iterable"]
  }
}
