{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "spark-core": ["./packages/spark-core/src/index.ts"],
      "spark-artifacts": ["./packages/spark-artifacts/src/index.ts"],
      "pi-ask": ["./packages/pi-ask/src/index.ts"],
      "spark-ask": ["./packages/spark-ask/src/index.ts"],
      "pi-cue": ["./packages/pi-cue/src/index.ts"],
      "spark-agents": ["./packages/spark-agents/src/index.ts"],
      "spark-review": ["./packages/spark-review/src/index.ts"],
      "spark-tasks": ["./packages/spark-tasks/src/index.ts"]
    }
  }
}
