{
  "name": "@zendev-lab/spark-cue",
  "version": "0.1.0",
  "description": "Spark extension package that adds cue-shell as a durable, observable execution backend.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "skills/**/*",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@zendev-lab/spark-extension-api": "workspace:^",
    "@zendev-lab/spark-retry": "workspace:^",
    "@zendev-lab/spark-system": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  }
}
