{
  "name": "@zendev-lab/spark-cue",
  "version": "0.1.0",
  "private": true,
  "description": "Spark extension package that adds cue-shell as a durable, observable execution backend.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "skills/**/*",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension/index.ts"
  },
  "scripts": {
    "check": "vp check --no-fmt --no-lint . && vp test run",
    "test": "vp test run"
  },
  "dependencies": {
    "@zendev-lab/spark-core": "workspace:^",
    "@zendev-lab/spark-retry": "workspace:^",
    "@zendev-lab/spark-system": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  }
}
