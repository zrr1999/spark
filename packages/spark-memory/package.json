{
  "name": "@zendev-lab/spark-memory",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Spark memory capability with explicit scoped entries, keyword search, and policy-only prompting.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts",
    "./recall": "./src/recall-store.ts",
    "./learning": "./src/learning-store.ts",
    "./compaction-candidates": "./src/compaction-candidates.ts",
    "./reflection-candidate-inbox": "./src/reflection-candidate-inbox.ts",
    "./reflection-in-session-scheduler": "./src/reflection-in-session-scheduler.ts",
    "./reflection-session-scanner": "./src/reflection-session-scanner.ts",
    "./reflection-synthesis-engine": "./src/reflection-synthesis-engine.ts"
  },
  "dependencies": {
    "@zendev-lab/spark-artifacts": "workspace:^",
    "@zendev-lab/spark-core": "workspace:^",
    "@zendev-lab/spark-system": "workspace:^",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension-entry.ts"
    ]
  }
}
