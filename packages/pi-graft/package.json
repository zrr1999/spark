{
  "name": "@zendev-lab/pi-graft",
  "version": "0.1.0",
  "description": "Pi extension package for graft daemon scratch and candidate workflows.",
  "keywords": [
    "graft",
    "pi-extension",
    "pi-package"
  ],
  "license": "MIT",
  "author": "zrr1999",
