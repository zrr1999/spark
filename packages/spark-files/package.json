{
  "name": "@zendev-lab/spark-files",
  "version": "0.1.0",
  "private": true,
  "description": "Working-tree file tools (read/edit/write/grep/find/ls) for Spark extension hosts, with Pi-parity truncation and diff semantics.",
  "keywords": [
    "file-tools",
    "spark-extension",
    "spark-package"
  ],
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts"
  },
  "scripts": {
    "check": "vp check --no-fmt --no-lint ."
  },
  "dependencies": {
    "@zendev-lab/spark-core": "workspace:^",
    "diff": "^8.0.4",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension-entry.ts"
    ]
  }
}
