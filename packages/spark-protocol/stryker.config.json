{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": [
    "src/action-bars.ts",
    "src/ask-semantics.ts",
    "src/command-delivery.ts",
    "src/command-events.ts",
    "src/command-sources.ts",
    "src/invocation-lifecycle.ts",
    "src/model-control-client.ts",
    "src/model-control.ts",
    "src/refs.ts",
    "src/runtime-v1/messages.ts",
    "src/session-assignment.ts",
    "src/state-ownership.ts",
    "src/tool-display.ts",
    "src/version.ts"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "ignorePatterns": ["reports", ".stryker-tmp"],
  "reporters": ["clear-text", "progress", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "incremental": true,
  "incrementalFile": "reports/mutation/incremental.json",
  "thresholds": {
    "high": 90,
    "low": 70,
    "break": null
  },
  "timeoutMS": 20000,
  "concurrency": 4,
  "ignoreStatic": true
}
