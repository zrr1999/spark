{
  "name": "@zendev-lab/spark-roles",
  "version": "0.1.0",
  "description": "Canonical role tool, reusable role specs, model settings, and anonymous role runs.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts",
    "./reviewer-runner": "./src/reviewer-runner.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "vp check --no-fmt --no-lint ."
  },
  "dependencies": {
    "@zendev-lab/spark-core": "workspace:^",
    "@zendev-lab/spark-host": "workspace:^",
    "@zendev-lab/spark-system": "workspace:^",
    "@zendev-lab/spark-tui": "workspace:^",
    "es-toolkit": "catalog:",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension-entry.ts"
    ]
  }
}
