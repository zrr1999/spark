{
  "name": "@zendev-lab/spark-graft",
  "version": "0.1.0",
  "description": "Spark extension package for graft daemon scratch and candidate workflows.",
  "keywords": [
    "graft",
    "spark-extension",
    "spark-package"
  ],
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts",
    "./sandbox": "./src/sandbox-entry.ts",
    "./graft-client": "./src/graft-client.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "vp check --no-fmt --no-lint ."
  },
  "dependencies": {
    "@zendev-lab/spark-extension-api": "workspace:^",
    "@zendev-lab/spark-roles": "workspace:^",
    "typebox": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension-entry.ts"
    ]
  }
}
