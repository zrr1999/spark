{
  "name": "@zendev-lab/spark-artifacts",
  "version": "0.1.0",
  "description": "Product artifacts (issue/pr/preview) and internal evidence storage for Spark capability hosts.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts",
    "./generative-ui": "./src/generative-ui.ts",
    "./product": "./src/product/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "vp check --no-fmt --no-lint . && vp test run",
    "test": "vp test run",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@zendev-lab/spark-core": "workspace:^",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pi": {
    "extensions": [
      "./src/extension-entry.ts"
    ]
  }
}
