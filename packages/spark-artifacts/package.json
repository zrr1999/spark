{
  "name": "@zendev-lab/spark-artifacts",
  "version": "0.1.0",
  "description": "Artifact/evidence storage and canonical artifact tool for Spark capability hosts.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
