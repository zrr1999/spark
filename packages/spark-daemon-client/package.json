{
  "name": "@zendev-lab/spark-daemon-client",
  "version": "0.1.0",
  "private": true,
  "description": "Protocol-aware local client transport for the Spark daemon.",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./local-rpc": "./src/daemon-local-rpc.ts",
