{
  "name": "@zendev-lab/pi-workflows",
  "version": "0.1.0",
  "description": "Generic saved workflow discovery, script runtime, and workflow/DAG run-store capability for Pi extensions.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@zendev-lab/pi-extension-api": "workspace:^",
    "@zendev-lab/pi-tasks": "workspace:^",
    "typebox": "^1.1.38"
  },
  "pi": {
    "extensions": [
      "./src/extension-entry.ts"
    ]
  }
}
