{
  "name": "@zendev-lab/spark-i18n",
  "version": "0.1.0",
  "description": "Shared Spark localization helpers and Inlang/Paraglide message boundary.",
  "license": "MIT",
  "author": "zrr1999",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "src/**/*.json",
    "src/paraglide/**/*.js",
    "src/paraglide/**/*.d.ts",
    "scripts/*.mjs",
    "project.inlang/**/*",
    "messages/**/*",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./extension": "./src/extension.ts",
    "./paraglide/messages": "./src/paraglide/messages.js",
    "./paraglide/runtime": "./src/paraglide/runtime.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate-paraglide.mjs && node scripts/allow-generated-output.mjs",
    "check": "pnpm run generate && vp check --no-fmt --no-lint . && vp test run",
    "test": "vp test run"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.20.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=26.0.0 <27"
  }
}
