{
  "name": "@zendev-lab/spark-cockpit",
  "version": "0.1.0",
  "description": "Spark Cockpit SvelteKit web application.",
  "bin": {
    "spark-cockpit": "./bin/spark-cockpit"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp dev --host 127.0.0.1",
    "build": "vp build",
    "preview": "vp preview --host 127.0.0.1",
    "start": "node build",
    "start:custom": "tsx server/index.ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vp test run"
  },
  "dependencies": {
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/adapter-node": "^5.3.1",
    "@sveltejs/kit": "^2.28.0",
    "@zendev-lab/spark-db": "workspace:*",
    "@zendev-lab/spark-i18n": "workspace:*",
    "@zendev-lab/spark-protocol": "workspace:*",
    "@zendev-lab/spark-system": "workspace:*",
    "smol-toml": "^1.6.1",
    "svelte": "^5.38.8",
    "vite": "catalog:",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/ws": "^8.18.1",
    "svelte-check": "^4.3.1",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=26.0.0 <27"
  }
}
