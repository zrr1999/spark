#!/usr/bin/env sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
APP_DIR="$SCRIPT_DIR/.."

print_help() {
  cat <<'EOF'
spark cockpit - Cockpit web UI host

Usage:
  spark cockpit [start]
  spark cockpit dev [vite args...]
  spark cockpit preview [vite args...]
  spark cockpit build
  spark cockpit --help

Commands:
  start          Start the built Cockpit web UI (default)
  dev            Start the Cockpit development server on 127.0.0.1
  preview        Start SvelteKit/Vite preview for an already-built Cockpit app
  build          Build the Cockpit production app

Plane boundary:
  Cockpit is the web UI host, not a fourth command plane.
  Coordination commands belong under spark server.
  Execution controls belong under spark daemon.

Environment:
  HOST=0.0.0.0                 Intentionally listen on all interfaces
  SPARK_COCKPIT_REMOTE_TOKEN    Required for non-localhost browser/API access
  PORT=5174                     Override the default port

Examples:
  spark cockpit build
  spark cockpit
  PORT=5174 spark cockpit
  HOST=0.0.0.0 SPARK_COCKPIT_REMOTE_TOKEN=... spark cockpit
EOF
}

command="${1:-start}"
case "$command" in
  help|--help|-h)
    print_help
    ;;
  start)
    shift || true
    if [ ! -f "$APP_DIR/build/handler.js" ]; then
      printf 'Spark Cockpit production build not found. Run "spark cockpit build" first.\n' >&2
      exit 1
    fi
    cd "$APP_DIR"
    exec pnpm run start:custom -- "$@"
    ;;
  dev)
    shift
    cd "$APP_DIR"
    exec pnpm run dev -- "$@"
    ;;
  preview)
    shift
    cd "$APP_DIR"
    exec pnpm run preview -- "$@"
    ;;
  build)
    shift
    cd "$APP_DIR"
    exec pnpm run build -- "$@"
    ;;
  *)
    printf 'Unknown spark-cockpit command: %s\nRun "spark cockpit --help" for available commands.\n' "$command" >&2
    exit 2
    ;;
esac
