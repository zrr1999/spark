#!/usr/bin/env sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
APP_DIR="$SCRIPT_DIR/.."

print_help() {
  cat <<'EOF'
spark cockpit - Spark cross-daemon coordination and Web cockpit

Usage:
  spark cockpit
  spark cockpit status [--json]
  spark cockpit project list [--json]
  spark cockpit task list [--project <project-ref>] [--json]
  spark cockpit goal status [--json]
  spark cockpit artifact list [--json]
  spark cockpit review list [--json]
  spark cockpit workflow list [--json]
  spark cockpit assign --session <session-id> --goal <text> [--json]
  spark cockpit --help

Commands:
  (no command)  Start the built production Cockpit Web host
  status        Show cross-daemon coordination status
  project       Query projects
  task          Query tasks
  goal          Query the active goal
  artifact      Query artifacts
  review        Query reviews
  workflow      Query workflow runs
  assign        Queue work through the coordination plane

Cockpit coordinates across daemon execution planes; spark tui is the terminal presentation host.

Production start environment:
  HOST=0.0.0.0                         Intentionally listen on all interfaces
  PORT=5174                            Override the default port
  SPARK_COCKPIT_PUBLIC_URL=https://spark.example.com
                                        Canonical public origin for a custom domain
  SPARK_COCKPIT_PUBLIC_URL=auto        Derive the origin from a trusted proxy request
  SPARK_COCKPIT_TRUST_PROXY=loopback   Trust forwarded headers from a loopback proxy
  SPARK_COCKPIT_PROXY_HOPS=1           Select the client entry in X-Forwarded-For
  SPARK_COCKPIT_REMOTE_TOKEN           Required for non-localhost browser/API access

Examples:
  spark cockpit
  spark cockpit status --json
  PORT=5174 spark cockpit
  HOST=0.0.0.0 SPARK_COCKPIT_REMOTE_TOKEN=... spark cockpit
  HOST=127.0.0.1 SPARK_COCKPIT_PUBLIC_URL=https://spark.example.com \
    SPARK_COCKPIT_TRUST_PROXY=loopback SPARK_COCKPIT_REMOTE_TOKEN=... spark cockpit
EOF
}

command="${1:-start}"
case "$command" in
  help|--help|-h)
    print_help
    ;;
  start)
    shift || true
    if [ ! -f "$APP_DIR/build/handler.js" ]; then
      printf 'Spark Cockpit production build not found. Build the app through its package script before starting it.\n' >&2
      exit 1
    fi
    cd "$APP_DIR"
    exec pnpm run start:custom -- "$@"
    ;;
  status|project|task|goal|artifact|review|workflow|assign)
    exec "$APP_DIR/node_modules/.bin/tsx" "$APP_DIR/src/cli-entry.ts" "$@"
    ;;
  *)
    printf 'Unknown spark cockpit command: %s\nRun "spark cockpit --help" for available commands.\n' "$command" >&2
    exit 2
    ;;
esac
