{
  "name": "@zendev-lab/spark-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4322",
    "build": "astro build",
    "preview": "astro preview --port 4322",
    "check:content": "node ../../scripts/check-user-docs.mjs",
    "check:deploy": "node ../../scripts/require-docs-deploy-env.mjs",
    "check:dist": "node ../../scripts/check-user-docs.mjs --dist",
    "check": "pnpm run check:content && astro check && astro build && pnpm run check:dist",
    "deploy": "pnpm run check:deploy && astro build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.4",
    "astro": "7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "catalog:",
    "wrangler": "4.113.0"
  },
  "engines": {
    "node": ">=26.0.0 <27",
    "pnpm": ">=11 <12"
  }
}
