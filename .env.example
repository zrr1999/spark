# Copy to .env for local development. Keep real secrets out of git.

# Optional all-in-one root for Spark-owned user paths.
# When unset, Spark follows XDG_CONFIG_HOME, XDG_DATA_HOME, XDG_CACHE_HOME,
# XDG_STATE_HOME, and XDG_RUNTIME_DIR with standard $HOME fallbacks.
SPARK_HOME=

# Spark Baidu OneAPI provider. Required only when selecting baidu-oneapi models.
BAIDU_ONEAPI_API_KEY=
BAIDU_ONEAPI_BASE_URL=
BAIDU_ONEAPI_OPENAI_BASE_URL=

# Spark daemon workspace registration. Prefer passing tokens through stdin or CI secrets.
SPARK_WORKSPACE_REGISTRATION_TOKEN=

# Optional development overrides.
SPARK_DAEMON_CWD=
SPARK_REPO_ROOT=
SPARK_GIT_COMMAND=
