# Copy to .env for local development. Keep real secrets out of git.

# Spark host state. Defaults to ~/.spark when unset.
SPARK_HOME=
SPARK_AGENT_DIR=

# Spark Baidu OneAPI provider. Required only when selecting baidu-oneapi models.
BAIDU_ONEAPI_API_KEY=
BAIDU_ONEAPI_BASE_URL=
BAIDU_ONEAPI_OPENAI_BASE_URL=

# Navia runner registration. Prefer passing tokens through stdin or CI secrets.
NAVIA_WORKSPACE_REGISTRATION_TOKEN=

# Optional Navia runner/server storage overrides. Defaults follow XDG/home cache locations.
NAVIA_RUNNER_DATA_DIR=
NAVIA_RUNNER_CACHE_DIR=
NAVIA_RUNNER_STATE_DIR=
NAVIA_RUNNER_CWD=
NAVIA_SERVER_DATA_DIR=
NAVIA_SERVER_CACHE_DIR=
NAVIA_SERVER_STATE_DIR=

# Optional development overrides.
NAVIA_REPO_ROOT=
NAVIA_GIT_COMMAND=
